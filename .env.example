# --- Notion (アプリ本体のDB) ---
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_SITES_DB_ID=
NOTION_SETTINGS_DB_ID=

# --- Googleログイン (Auth.js v5。各プロバイダーIDに合わせた命名規則) ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ALLOWED_EMAILS=

# --- Slack通知 (Settings DBのON/OFFはこのURLがある場合のみ有効) ---
SLACK_WEBHOOK_URL=

# --- AIプロバイダーAPIキー (使用するプロバイダーはSettings DBで選択) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- 以下は scripts/migrate-sheet-to-notion.ts を1回限り実行するためだけに必要 ---
# (移行完了後は不要。WordPress認証情報はNotionのSites DBに移行される)
WP_URL=
WP_USER=
WP_APP_PASSWORD=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=keywords
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json
# 移行元サイトの名前・キャラ設定・コードブロック形式（任意）。サイト固有の内容なのでここには書かず.envにのみ設定する
MIGRATE_SITE_NAME=
MIGRATE_SYSTEM_PROMPT=
MIGRATE_CODE_BLOCK_FORMAT=
